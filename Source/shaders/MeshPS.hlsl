// MeshPS.hlsl
// Cook-Torrance GGX PBR pixel shader.
// Matches the lecture (Microgeometry / microfacet theory) and the teacher's
// Exercise10 reference implementation.

// ??????????????????????????????????????????????????????????????????????????????
// Light structure limits  (must match MeshPipeline.h)
// ??????????????????????????????????????????????????????????????????????????????
#define MAX_DIR_LIGHTS    4
#define MAX_POINT_LIGHTS 32
#define MAX_SPOT_LIGHTS  16

static const float PI = 3.14159265359f;

// ??????????????????????????????????????????????????????????????????????????????
// Light structures  (must be byte-identical to MeshPipeline::GPU* structs)
// ??????????????????????????????????????????????????????????????????????????????
struct DirectionalLight
{
    float3 direction; // world-space direction the light points *towards*
    float intensity;
    float3 color;
    float pad;
};

struct PointLight
{
    float3 position;
    float sqRadius; // radius˛  (falloff goes to zero at sqrt(sqRadius))
    float3 color;
    float intensity;
};

struct SpotLight
{
    float3 position;
    float sqRadius;
    float3 direction; // world-space direction the cone points *towards*
    float innerCos; // cos(inner half-angle)
    float3 color;
    float outerCos; // cos(outer half-angle)
    float intensity;
    float pad0;
    float2 pad;
};

// ??????????????????????????????????????????????????????????????????????????????
// Constant buffers
// ??????????????????????????????????????????????????????????????????????????????
cbuffer LightCB : register(b2)
{
    float3 ambientColor;
    float ambientIntensity;

    float3 viewPos; // camera world position
    float pad0;

    uint numDirLights;
    uint numPointLights;
    uint numSpotLights;
    uint iblEnabled; // 1 when an environment map is bound

    float numRoughnessLevels; // mip count of the pre-filtered env map
    float3 pad1;

    DirectionalLight dirLights[MAX_DIR_LIGHTS];
    PointLight pointLights[MAX_POINT_LIGHTS];
    SpotLight spotLights[MAX_SPOT_LIGHTS];
};

cbuffer MaterialCB : register(b3)
{
    float4 baseColor;
    float metallic;
    float roughness;
    float normalStrength;
    float aoStrength;

    uint hasBaseColorTexture;
    uint hasNormalMap;
    uint hasAOMap;
    uint hasEmissiveMap;

    uint hasMetalRoughMap;
    float3 emissiveFactor;

    uint samplerIndex; // currently unused; kept for CB layout compatibility
};

// ??????????????????????????????????????????????????????????????????????????????
// Texture registers  (match root-signature slot order in MeshPipeline.cpp)
// ??????????????????????????????????????????????????????????????????????????????
Texture2D albedoTex : register(t0);
TextureCube irradianceMap : register(t1);
TextureCube prefilteredMap : register(t2);
Texture2D brdfLUT : register(t3);
Texture2D normalMapTex : register(t4);
Texture2D aoTex : register(t5);
Texture2D emissiveTex : register(t6);
Texture2D metalRoughTex : register(t7);

SamplerState samplers[4] : register(s0);
// samplers[0] = aniso/linear wrap   (for material textures)
// samplers[2] = linear clamp        (for IBL lookups)

// ??????????????????????????????????????????????????????????????????????????????
// PS input  (must match VSOutput in MeshVS.hlsl)
// ??????????????????????????????????????????????????????????????????????????????
struct PSInput
{
    float4 pos : SV_POSITION;
    float2 uv : TEXCOORD;
    float3 worldPos : POSITION;
    float3 nrm : NORMAL;
    float4 tangent : TANGENT;
};

// ??????????????????????????????????????????????????????????????????????????????
// Colour-space helpers
// ??????????????????????????????????????????????????????????????????????????????
static const float GAMMA = 2.2f;
static const float INV_GAMMA = 1.0f / GAMMA;

float3 linearToSRGB(float3 c)
{
    return pow(max(c, 0.0f), INV_GAMMA);
}
float3 sRGBToLinear(float3 c)
{
    return pow(max(c, 0.0f), GAMMA);
}

// ??????????????????????????????????????????????????????????????????????????????
// PBR-neutral tone-mapper  (same as teacher's tonemap.hlsli)
// ??????????????????????????????????????????????????????????????????????????????
float3 PBRNeutralToneMapping(float3 color)
{
    const float startCompression = 0.8f - 0.04f;
    const float desaturation = 0.15f;

    float x = min(color.r, min(color.g, color.b));
    float offset = x < 0.08f ? x - 6.25f * x * x : 0.04f;
    color -= offset;

    float peak = max(color.r, max(color.g, color.b));
    if (peak < startCompression)
        return color;

    const float d = 1.0f - startCompression;
    float newPeak = 1.0f - d * d / (peak + d - startCompression);
    color *= newPeak / peak;

    float g = 1.0f - 1.0f / (desaturation * (peak - newPeak) + 1.0f);
    return lerp(color, newPeak, g);
}

// ??????????????????????????????????????????????????????????????????????????????
// BRDF building blocks
// ??????????????????????????????????????????????????????????????????????????????

// Schlick Fresnel  (lecture slide 28)
// f0  = reflectance at normal incidence
// f90 = reflectance at grazing (1.0 for dielectrics & metals)
float3 F_Schlick(float3 f0, float f90, float cosTheta)
{
    return f0 + (f90 - f0) * pow(1.0f - cosTheta, 5.0f);
}

// Scalar overload used for the dielectric constant (0.04)
float F_Schlick(float f0, float f90, float cosTheta)
{
    return f0 + (f90 - f0) * pow(1.0f - cosTheta, 5.0f);
}

// GGX Normal Distribution Function  (lecture slide 18 – D_ggx)
// alpha = roughness˛  (perceptual roughness is squared before passing in)
float D_GGX(float alpha, float NdotH)
{
    float a2 = alpha * alpha;
    float denom = NdotH * NdotH * (a2 - 1.0f) + 1.0f;
    return (denom > 0.0f) ? a2 / (PI * denom * denom) : 0.0f;
}

// Height-correlated Smith GGX Visibility function  (lecture slides 24-26)
// Returns  G(L,V,H) / (4·NdotL·NdotV)  combined into a single term.
float V_SmithGGXCorrelated(float NdotV, float NdotL, float alpha)
{
    float a2 = alpha * alpha;
    // Lambda terms for view and light directions
    float lambdaV = NdotL * sqrt(NdotV * NdotV * (1.0f - a2) + a2);
    float lambdaL = NdotV * sqrt(NdotL * NdotL * (1.0f - a2) + a2);
    float denom = lambdaV + lambdaL;
    return (denom > 0.0f) ? 0.5f / denom : 0.0f;
}

// Lambert diffuse  (1/?, the ? cancels with the BRDF integration weight)
float3 Lambert(float3 diffuseColor)
{
    return diffuseColor / PI;
}

// ??????????????????????????????????????????????????????????????????????????????
// Normal-map decode  (tangent ? world space)
// ??????????????????????????????????????????????????????????????????????????????
float3 applyNormalMap(float3 N, float4 T, float2 uv)
{
    // Sample and decode [0,1] ? [-1,1]
    float3 tn = normalMapTex.Sample(samplers[0], uv).rgb * 2.0f - 1.0f;
    tn.xy *= normalStrength;
    tn = normalize(tn);

    // Build TBN matrix
    float3 Nt = normalize(N);
    float3 Tt = normalize(T.xyz);
    float3 Bt = cross(Nt, Tt) * T.w; // T.w holds the bitangent sign

    return normalize(Tt * tn.x + Bt * tn.y + Nt * tn.z);
}

// ??????????????????????????????????????????????????????????????????????????????
// Specular AO  (horizon-based approximation, removes energy above the surface)
// ??????????????????????????????????????????????????????????????????????????????
float computeSpecularAO(float NdotV, float ao, float rough)
{
    return saturate(pow(NdotV + ao, exp2(-16.0f * rough - 1.0f)) - 1.0f + ao);
}

// ??????????????????????????????????????????????????????????????????????????????
// Core Cook-Torrance evaluation  (called per light)
// Matches the teacher's computeLighting() + GGX() breakdown exactly.
// ??????????????????????????????????????????????????????????????????????????????
float3 cookTorranceGGX(
    float3 N, // surface normal (world, normalised)
    float3 L, // direction *to* the light (world, normalised)
    float3 V, // direction *to* the camera (world, normalised)
    float3 albedo, // linear base colour
    float metal, // 0 = dielectric, 1 = metal
    float alpha, // roughness˛  (alpha roughness)
    float3 lightColor,
    float lightIntensity)
{
    float3 H = normalize(L + V);
    float NdotL = saturate(dot(N, L));
    float NdotV = saturate(dot(N, V));
    float NdotH = saturate(dot(N, H));
    float VdotH = saturate(dot(V, H)); // = LdotH for the half-vector

    // Early-out: light is behind the surface
    if (NdotL <= 0.0f)
        return 0.0f;

    // ?? Fresnel ????????????????????????????????????????????????????????????
    // F0 for metals   = tinted by albedo  (lecture slide 29)
    // F0 for dielectrics = 0.04           (lecture slide 30)
    float3 F0 = lerp(float3(0.04f, 0.04f, 0.04f), albedo, metal);
    float3 metalF = F_Schlick(F0, 1.0f, VdotH);
    float dielF = F_Schlick(0.04f, 1.0f, VdotH); // scalar

    // ?? Specular lobe (D · V term) ?????????????????????????????????????????
    float D = D_GGX(alpha, NdotH);
    float Vis = V_SmithGGXCorrelated(NdotV, NdotL, alpha);
    // The ×4 denominator is already inside V_SmithGGXCorrelated (returns 0.5/…)
    float3 spec = D * Vis * NdotL * lightColor * lightIntensity;

    // ?? Diffuse lobe ???????????????????????????????????????????????????????
    float3 diff = Lambert(albedo) * NdotL * lightColor * lightIntensity;

    // ?? Blend metal vs dielectric  (lecture slide 31-32) ??????????????????
    // Dielectrics: diffuse + Fresnel-weighted specular; no colour on specular.
    // Metals:      no diffuse, specular tinted by F0 (= albedo for metals).
    float3 dielectricContrib = diff * (1.0f - dielF) + spec * dielF;
    float3 metalContrib = spec * metalF;

    return lerp(dielectricContrib, metalContrib, metal);
}

// ??????????????????????????????????????????????????????????????????????????????
// Light-type wrappers
// ??????????????????????????????????????????????????????????????????????????????

// ---- Directional ----
float3 evaluateDirectional(DirectionalLight light,
    float3 N, float3 V, float3 albedo, float metal, float alpha)
{
    float3 L = normalize(-light.direction); // flip: direction stores "towards light target"
    return cookTorranceGGX(N, L, V, albedo, metal, alpha,
                           light.color, light.intensity);
}

// ---- Point (lecture slide – pointFalloff) ----
float pointFalloff(float sqDist, float sqRadius)
{
    // UE4 / glTF physical falloff: (1 - (d˛/r˛)˛)˛ / (d˛+1)
    float num = max(1.0f - (sqDist / sqRadius) * (sqDist / sqRadius), 0.0f);
    return (num * num) / (sqDist + 1.0f);
}

float3 evaluatePoint(PointLight light,
    float3 worldPos, float3 N, float3 V,
    float3 albedo, float metal, float alpha)
{
    float3 toLight = light.position - worldPos;
    float sqDist = dot(toLight, toLight);
    float atten = pointFalloff(sqDist, max(light.sqRadius, 1e-6f));
    float3 L = normalize(toLight);
    return cookTorranceGGX(N, L, V, albedo, metal, alpha,
                           light.color, light.intensity) * atten;
}

// ---- Spot (lecture slide – spotFalloff) ----
float spotFalloff(float cosDist, float innerCos, float outerCos)
{
    float angleAtt = saturate((cosDist - outerCos) / max(innerCos - outerCos, 1e-6f));
    return angleAtt * angleAtt;
}

float3 evaluateSpot(SpotLight light,
    float3 worldPos, float3 N, float3 V,
    float3 albedo, float metal, float alpha)
{
    float3 toLight = light.position - worldPos;
    float3 L = normalize(toLight);

    // Distance falloff along the cone axis (matches teacher's code exactly)
    float dist = dot(-toLight, light.direction);
    float distAtten = pointFalloff(dist * dist, max(light.sqRadius, 1e-6f));

    // Angular (cone) falloff
    float cosDist = dot(-L, normalize(light.direction));
    float coneAtten = spotFalloff(cosDist, light.innerCos, light.outerCos);

    return cookTorranceGGX(N, L, V, albedo, metal, alpha,
                           light.color, light.intensity)
           * distAtten * coneAtten;
}

// ??????????????????????????????????????????????????????????????????????????????
// IBL ambient  (split-sum approximation, lecture slide 35)
// ??????????????????????????????????????????????????????????????????????????????
// getDiffuseAmbient: irradiance convolution cube × diffuse albedo.
float3 getDiffuseAmbient(float3 N, float3 albedo)
{
    return irradianceMap.Sample(samplers[2], N).rgb * albedo;
}

// getSpecularAmbient: pre-filtered env map + BRDF LUT split-sum.
// Returns the full specular radiance term *before* Fresnel split.
//   firstTerm  = radiance × fab.x   (scale  – multiplied by F0 by the caller)
//   secondTerm = radiance × fab.y   (bias   – added directly by the caller)
void getSpecularAmbientTerms(float3 R, float NdotV, float rough,
                              out float3 firstTerm, out float3 secondTerm)
{
    float mip = rough * (numRoughnessLevels - 1.0f);
    float3 radiance = prefilteredMap.SampleLevel(samplers[2], R, mip).rgb;
    float2 fab = brdfLUT.Sample(samplers[2], float2(NdotV, rough)).rg;

    firstTerm = radiance * fab.x;
    secondTerm = radiance * fab.y;
}

// Full IBL evaluation (diffuse + specular, metal/dielectric blend).
// F0 is lerped from 0.04 (dielectric) to albedo (metal) – lecture slide 31.
float3 evaluateIBL(float3 N, float3 V, float3 R,
                   float3 albedo, float metal, float rough,
                   float diffuseAO, float specularAO)
{
    // ?? Diffuse ????????????????????????????????????????????????????????????
    float3 diffuse = getDiffuseAmbient(N, albedo) * diffuseAO;

    // ?? Specular (split-sum) ???????????????????????????????????????????????
    float NdotV = saturate(dot(N, V));
    float3 firstTerm, secondTerm;
    getSpecularAmbientTerms(R, NdotV, rough, firstTerm, secondTerm);

    // Apply Fresnel split:
    //   metal    F0 = albedo         ? spec = albedo·scale + bias
    //   dielectric F0 = 0.04         ? spec = 0.04·scale  + bias
    float3 metalSpec = (albedo * firstTerm + secondTerm) * specularAO;
    float3 dielectricSpec = (float3(0.04f, 0.04f, 0.04f) * firstTerm + secondTerm) * specularAO;

    // Blend using metalness mask (lecture slide 31-32)
    float3 metalContrib = metalSpec;
    float3 dielectricContrib = diffuse + dielectricSpec;

    return lerp(dielectricContrib, metalContrib, metal);
}

// ??????????????????????????????????????????????????????????????????????????????
// Main pixel shader entry point
// ??????????????????????????????????????????????????????????????????????????????
float4 main(PSInput input) : SV_TARGET
{
    // ?? Sample material properties ?????????????????????????????????????????

    // Base colour (sRGB texture ? keep as-is; GPU hardware sRGB decode handles it
    // when the SRV is created with a _SRGB format)
    float3 albedo = baseColor.rgb;
    if (hasBaseColorTexture)
        albedo *= albedoTex.Sample(samplers[0], input.uv).rgb;

    // Metallic-roughness texture:
    //   glTF spec: G channel = roughness, B channel = metallic   (lecture slide 37)
    //   FIX: was .gb which gave correct channels but wrong variable assignment.
    //        .bg ? x = blue = metallic,  y = green = roughness
    float metal = metallic;
    float rough = roughness;
    if (hasMetalRoughMap)
    {
        float2 mr = metalRoughTex.Sample(samplers[0], input.uv).bg;
        metal *= mr.x; // blue  channel = metallic
        rough *= mr.y; // green channel = roughness
    }
    rough = max(rough, 0.04f); // clamp away near-zero roughness
    float alpha = rough * rough; // perceptual roughness ? alpha (lecture slide 37)

    // ?? Surface normal ?????????????????????????????????????????????????????
    float3 N = normalize(input.nrm);
    if (hasNormalMap)
        N = applyNormalMap(input.nrm, input.tangent, input.uv);

    // ?? View direction & reflection ????????????????????????????????????????
    float3 V = normalize(viewPos - input.worldPos);
    float3 R = reflect(-V, N);

    // ?? Ambient occlusion ??????????????????????????????????????????????????
    float diffuseAO = 1.0f;
    float specularAO = 1.0f;
    if (hasAOMap)
    {
        diffuseAO = lerp(1.0f, aoTex.Sample(samplers[0], input.uv).r, aoStrength);
        // specularAO: horizon approximation – only attenuates, never amplifies
        specularAO = computeSpecularAO(saturate(dot(N, V)), diffuseAO, rough);
        // FIX: removed the incorrect  specularAO *= max(1 + NdotR, 1)  line
        //      which was wrongly amplifying AO above 1.0
    }

    // ?? Direct lighting ????????????????????????????????????????????????????
    float3 directLight = 0.0f;

    for (uint i = 0; i < numDirLights; ++i)
        directLight += evaluateDirectional(dirLights[i], N, V, albedo, metal, alpha);

    for (uint i = 0; i < numPointLights; ++i)
        directLight += evaluatePoint(pointLights[i], input.worldPos, N, V, albedo, metal, alpha);

    for (uint i = 0; i < numSpotLights; ++i)
        directLight += evaluateSpot(spotLights[i], input.worldPos, N, V, albedo, metal, alpha);

    // ?? Ambient / IBL ??????????????????????????????????????????????????????
    float3 ambient = 0.0f;

    if (iblEnabled)
    {
        ambient = evaluateIBL(N, V, R, albedo, metal, rough,
                              diffuseAO, specularAO);
    }
    else
    {
        // Flat ambient fallback (no environment map loaded)
        ambient = ambientColor * ambientIntensity * albedo * diffuseAO;
        ambient = max(ambient, albedo * 0.03f); // minimum so nothing is pitch black
    }

    // ?? Emissive ???????????????????????????????????????????????????????????
    float3 emissive = 0.0f;
    if (hasEmissiveMap)
        emissive = emissiveTex.Sample(samplers[0], input.uv).rgb * emissiveFactor;

    // ?? Combine, tone-map, gamma-encode ???????????????????????????????????
    float3 hdr = emissive + ambient + directLight;
    float3 ldr = PBRNeutralToneMapping(hdr);
    return float4(linearToSRGB(ldr), baseColor.a);
}
